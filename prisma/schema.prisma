generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
  banned
}

enum UserRole {
  user
  author
  admin
  superadmin
}

enum ResourceStatus {
  draft
  pending
  published
  archived
  rejected
}

enum SubmissionStatus {
  draft
  pending
  approved
  rejected
  withdrawn
}

enum UploadDriver {
  local
  cos
  s3
}

enum UploadStatus {
  pending
  uploaded
  attached
  deleted
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  name         String
  passwordHash String
  role         UserRole           @default(user)
  status       UserStatus         @default(active)
  avatarUrl    String?
  bio          String?
  sessions     Session[]
  codes        VerificationCode[]
  resources    Resource[]         @relation("ResourceAuthor")
  submissions  Submission[]
  uploads      UploadAsset[]
  favorites    Favorite[]
  downloads    DownloadEvent[]
  auditLogs    AuditLog[]         @relation("AuditActor")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  refreshHash String    @unique
  userAgent   String?
  ip          String?
  expiresAt   DateTime
  revokedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model VerificationCode {
  id         String    @id @default(cuid())
  email      String
  purpose    String
  codeHash   String
  attempts   Int       @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

model Resource {
  id               String          @id @default(cuid())
  slug             String          @unique
  titleZh          String
  titleEn          String?
  badge            String?
  coverImageUrl    String?
  coverCropY       Int             @default(50)
  showcaseImageUrl String?
  showcaseImages   Json?
  originalPostUrl  String?
  descriptionZh    String?
  descriptionEn    String?
  authorId         String?
  authorName       String
  roleId           String?
  rarity           String?
  version          String
  gameVersion      String?
  cardCount        Int             @default(0)
  sizeBytes        BigInt?
  packageAssetId   String?         @unique
  status           ResourceStatus  @default(draft)
  isVisible        Boolean         @default(true)
  downloads        Int             @default(0)
  hotScore         Int             @default(0)
  showOnHome       Boolean         @default(false)
  homeSortOrder    Int             @default(0)
  tone             String?
  publishedAt      DateTime?
  author           User?           @relation("ResourceAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  role             RoleOption?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  packageAsset     UploadAsset?     @relation("ResourcePackageAsset", fields: [packageAssetId], references: [id], onDelete: SetNull)
  tags             ResourceTag[]
  assets           UploadAsset[]
  favorites        Favorite[]
  downloadEvents   DownloadEvent[]
  submissions      Submission[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status, isVisible, publishedAt])
  @@index([showOnHome, homeSortOrder])
  @@index([roleId])
  @@index([hotScore])
}

model Tag {
  id        String        @id @default(cuid())
  key       String        @unique
  labelZh   String
  labelEn   String?
  resources ResourceTag[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ResourceTag {
  resourceId String
  tagId      String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
}

model RoleOption {
  id        String     @id @default(cuid())
  key       String     @unique
  labelZh   String
  labelEn   String?
  sortOrder Int        @default(0)
  resources Resource[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Submission {
  id           String           @id @default(cuid())
  submitterId  String
  resourceId   String?
  titleZh      String
  titleEn      String?
  description  String?
  version      String?
  status       SubmissionStatus @default(draft)
  reviewReason String?
  reviewedAt   DateTime?
  submitter    User             @relation(fields: [submitterId], references: [id], onDelete: Cascade)
  resource     Resource?        @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  assets       UploadAsset[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([submitterId])
  @@index([status])
}

model UploadAsset {
  id           String       @id @default(cuid())
  ownerId      String?
  resourceId   String?
  submissionId String?
  driver       UploadDriver @default(local)
  status       UploadStatus @default(pending)
  bucket       String?
  objectKey    String
  originalName String
  mimeType     String
  sizeBytes    BigInt
  publicUrl    String?
  owner        User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  resource     Resource?    @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  packageFor   Resource?    @relation("ResourcePackageAsset")
  submission   Submission?  @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([ownerId])
  @@index([resourceId])
  @@index([submissionId])
}

model Favorite {
  userId     String
  resourceId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, resourceId])
}

model DownloadEvent {
  id         String   @id @default(cuid())
  resourceId String
  userId     String?
  ipHash     String?
  userAgent  String?
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([resourceId, createdAt])
  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  ip         String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}
